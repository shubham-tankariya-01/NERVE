# Application environment
# Options: development, staging, production
APP_ENV=development
PORT=8000

# MongoDB
# Use a hosted MongoDB URI in staging/production.
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=nerve_db

# JWT secret
# Required in staging/production and should be a long random value.
JWT_SECRET_KEY=replace_with_a_long_random_secret

# CORS
# Comma-separated frontend origins. Wildcards are not allowed.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Runtime behavior
# Set to false on extra API instances if you do not want every instance running the scan loop.
ENABLE_BACKGROUND_SCANNER=true
SCAN_INTERVAL_SECONDS=10

# Email OTP delivery
# Required outside development because auth always sends email OTPs.
SENDGRID_API_KEY=replace_with_sendgrid_api_key
SENDGRID_FROM_EMAIL=no-reply@yourdomain.com

# Optional LLM features
# GROQ_API_KEY=replace_with_groq_api_key
